<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a0a2e"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvVolverVerificacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Volver"
                android:textColor="#d4aaff"
                android:textSize="14sp"
                android:padding="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔐 Verificar Identidad"
                android:textColor="#e8c3ff"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <View
                android:layout_width="80dp"
                android:layout_height="1dp"/>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvEstadoLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvEstadoObservacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#d4aaff"
                    android:textSize="13sp"
                    android:paddingTop="4dp"
                    android:visibility="gone"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Datos de Identidad"
            android:textColor="#d4aaff"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"/>

        <EditText
            android:id="@+id/etRut"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="RUT (ej: 12.345.678-9)"
            android:textColor="#ffffff"
            android:textColorHint="#9b59b6"
            android:background="#2d1654"
            android:padding="16dp"
            android:textSize="15sp"
            android:inputType="text"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvRutFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:paddingStart="4dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <EditText
            android:id="@+id/etNombreCompleto"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Nombre completo (como en cédula)"
            android:textColor="#ffffff"
            android:textColorHint="#9b59b6"
            android:background="#2d1654"
            android:padding="16dp"
            android:textSize="15sp"
            android:inputType="textPersonName|textCapWords"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷 Foto de Cédula de Identidad"
            android:textColor="#d4aaff"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Foto clara del frente de tu cédula (opcional para enviar, requerida para aprobar)"
            android:textColor="#9b59b6"
            android:textSize="12sp"
            android:paddingBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/ivPreviewCarnet"
                android:layout_width="110dp"
                android:layout_height="75dp"
                android:background="#2d1654"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera"
                android:contentDescription="Vista previa cédula"/>

            <Button
                android:id="@+id/btnSeleccionarFoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elegir foto"
                android:textColor="#ffffff"
                android:backgroundTint="#4a1a8e"
                android:layout_marginStart="12dp"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏦 Cuenta de Pago"
            android:textColor="#d4aaff"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Banco"
            android:textColor="#9b59b6"
            android:textSize="12sp"
            android:paddingBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerBanco"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#2d1654"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tipo de cuenta"
            android:textColor="#9b59b6"
            android:textSize="12sp"
            android:paddingBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerTipoCuenta"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#2d1654"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etNumeroCuenta"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Número de cuenta"
            android:textColor="#ffffff"
            android:textColorHint="#9b59b6"
            android:background="#2d1654"
            android:padding="16dp"
            android:textSize="15sp"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etTitularCuenta"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Titular de la cuenta"
            android:textColor="#ffffff"
            android:textColorHint="#9b59b6"
            android:background="#2d1654"
            android:padding="16dp"
            android:textSize="15sp"
            android:inputType="textPersonName|textCapWords"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvErrorVerif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#e74c3c"
            android:textSize="13sp"
            android:paddingBottom="8dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnEnviarVerificacion"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Enviar Solicitud de Verificación"
            android:textColor="#ffffff"
            android:backgroundTint="#7d3cae"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ℹ️ Tu solicitud será revisada en 1–3 días hábiles. Al ser verificada, aparecerá un badge en tu perfil público."
            android:textColor="#9b59b6"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.4"
            android:paddingBottom="32dp"/>

    </LinearLayout>
</ScrollView>
