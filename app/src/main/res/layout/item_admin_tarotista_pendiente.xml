<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="#2d1654"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvTarotistaNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#d4aaff"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvTarotistaDescripcion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9b59b6"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvTarotistaPrecio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#60e090"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvTarotistaEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnAprobarTarotista"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="✅ Aprobar"
                android:textColor="#ffffff"
                android:backgroundTint="#27ae60"
                android:textSize="13sp"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnRechazarTarotista"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="❌ Rechazar"
                android:textColor="#ffffff"
                android:backgroundTint="#e74c3c"
                android:textSize="13sp"
                android:layout_marginStart="6dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
