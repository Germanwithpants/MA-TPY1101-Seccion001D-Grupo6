<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="#1e0d3e"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvLogAccion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#d4aaff"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvLogTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9b59b6"
                android:textSize="10sp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvLogDetalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#e8c3ff"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvLogAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9b59b6"
            android:textSize="11sp"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
