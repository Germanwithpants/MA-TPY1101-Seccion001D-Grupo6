<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a0a2e"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="56dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:background="#2d1654">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Panel Admin 👑"
                android:textColor="#d4aaff"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvAdminLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salir"
                android:textColor="#e74c3c"
                android:textSize="14sp"
                android:padding="4dp"/>

        </LinearLayout>

        <!-- ── SECTION: DASHBOARD ────────────────────────────────────────── -->
        <ScrollView
            android:id="@+id/sectionDashboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:text="📊 Estadísticas del sistema"
                    android:textColor="#e8c3ff"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

                <ProgressBar
                    android:id="@+id/progressDashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:indeterminateTint="#7d3cae"
                    android:visibility="gone"/>

                <!-- Stat cards -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#2d1654"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:text="👥 Total Usuarios" android:textColor="#9b59b6" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvStatTotalUsuarios" android:textColor="#d4aaff" android:textSize="32sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—"/>
                        <TextView android:id="@+id/tvStatActivosUsuarios" android:textColor="#60e090" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="activos: —"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#2d1654"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:text="🔮 Tarotistas Activos" android:textColor="#9b59b6" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvStatTarotistaActivos" android:textColor="#d4aaff" android:textSize="32sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#2d1654"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:text="📅 Total Sesiones" android:textColor="#9b59b6" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvStatTotalSesiones" android:textColor="#d4aaff" android:textSize="32sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#2d1654"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:text="💰 Ingreso Total" android:textColor="#9b59b6" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvStatIngresoTotal" android:textColor="#60e090" android:textSize="28sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$—"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

        <!-- ── SECTION: USUARIOS ─────────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/sectionUsuarios"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:text="👥 Gestión de Usuarios"
                    android:textColor="#e8c3ff"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:padding="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <ProgressBar
                    android:id="@+id/progressUsuarios"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:indeterminateTint="#7d3cae"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvEmptyUsuarios"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No hay usuarios"
                    android:textColor="#9b59b6"
                    android:textSize="16sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="60dp"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvUsuarios"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"/>

            </LinearLayout>
        </FrameLayout>

        <!-- ── SECTION: TAROTISTAS ───────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/sectionTarotistas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:text="🔮 Tarotistas Pendientes"
                    android:textColor="#e8c3ff"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:padding="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <ProgressBar
                    android:id="@+id/progressTarotistas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:indeterminateTint="#7d3cae"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvEmptyTarotistas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No hay tarotistas pendientes ✅"
                    android:textColor="#60e090"
                    android:textSize="15sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="60dp"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTarotistas"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"/>

            </LinearLayout>
        </FrameLayout>

        <!-- ── SECTION: PAGOS ────────────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/sectionPagos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:text="💰 Pagos y Comisiones"
                    android:textColor="#e8c3ff"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:padding="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvResumenComisiones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#f39c12"
                    android:textSize="13sp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="8dp"/>

                <ProgressBar
                    android:id="@+id/progressPagos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:indeterminateTint="#7d3cae"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPagos"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"/>

            </LinearLayout>
        </FrameLayout>

        <!-- ── SECTION: LOGS ─────────────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/sectionDisputas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:text="⚠️ Disputas y Reportes"
                    android:textColor="#ffcc44"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:padding="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <ProgressBar
                    android:id="@+id/progressDisputas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:indeterminateTint="#7d3cae"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvEmptyDisputas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin disputas reportadas"
                    android:textColor="#9b59b6"
                    android:textSize="15sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="60dp"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDisputas"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"/>

            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#2d1654"
        app:itemIconTint="#d4aaff"
        app:itemTextColor="#d4aaff"
        app:menu="@menu/admin_bottom_nav_menu"
        app:labelVisibilityMode="labeled"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
