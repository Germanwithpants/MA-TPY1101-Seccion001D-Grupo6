<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a0a2e">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvVolverDisponibilidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Volver"
            android:textColor="#9b59b6"
            android:textSize="14sp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🗓 Mi Disponibilidad"
            android:textColor="#d4aaff"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <View android:layout_width="60dp" android:layout_height="1dp"/>

    </LinearLayout>

    <!-- Onboarding warning banner (hidden in normal mode) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bannerOnboarding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="#4a1a00"
        app:cardCornerRadius="10dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️  Paso obligatorio — sin esto no recibes clientes"
                android:textColor="#ffcc44"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Los clientes SOLO pueden reservar en los días y horas que configures aquí. Si no agregas ningún horario, tu perfil existirá pero nadie podrá agendarte.\n\nPuedes modificar esto en cualquier momento desde tu perfil."
                android:textColor="#ffeeaa"
                android:textSize="13sp"
                android:lineSpacingExtra="3dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Form to add slots -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agregar horario disponible"
                android:textColor="#e8c3ff"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Día de la semana"
                android:textColor="#9b59b6"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerDia"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#2d1654"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hora inicio"
                        android:textColor="#9b59b6"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etHoraInicio"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="09:00"
                        android:textColor="#ffffff"
                        android:textColorHint="#9b59b6"
                        android:background="#2d1654"
                        android:padding="12dp"
                        android:gravity="center"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hora fin"
                        android:textColor="#9b59b6"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etHoraFin"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="18:00"
                        android:textColor="#ffffff"
                        android:textColorHint="#9b59b6"
                        android:background="#2d1654"
                        android:padding="12dp"
                        android:gravity="center"/>

                </LinearLayout>

            </LinearLayout>

            <Button
                android:id="@+id/btnAgregarDisponibilidad"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="+ Agregar horario"
                android:textColor="#ffffff"
                android:backgroundTint="#7d3cae"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

    </ScrollView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Horarios configurados"
        android:textColor="#e8c3ff"
        android:textSize="15sp"
        android:textStyle="bold"
        android:paddingLeft="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"/>

    <ProgressBar
        android:id="@+id/progressDisponibilidad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvEmptyDisponibilidad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aún no has agregado horarios.\nAgrega al menos uno para continuar."
        android:textColor="#9b59b6"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDisponibilidad"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

    <!-- Onboarding continue button (hidden in normal mode) -->
    <Button
        android:id="@+id/btnContinuarOnboarding"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="12dp"
        android:text="Comenzar a recibir clientes"
        android:textColor="#ffffff"
        android:backgroundTint="#27ae60"
        android:textSize="15sp"
        android:textStyle="bold"
        android:enabled="false"
        android:visibility="gone"/>

</LinearLayout>
