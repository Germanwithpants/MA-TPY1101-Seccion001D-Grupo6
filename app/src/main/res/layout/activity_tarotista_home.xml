<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a0a2e"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#2d1654">

        <TextView
            android:id="@+id/tvBienvenidoTarotista"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#d4aaff"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvAjustesTarotista"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️"
            android:textSize="22sp"
            android:padding="8dp"/>

    </LinearLayout>

    <!-- Verification banner -->
    <LinearLayout
        android:id="@+id/bannerVerificacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#2a1040"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvBannerVerificacion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#f39c12"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvBannerVerificacionAccion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verificar →"
            android:textColor="#d4aaff"
            android:textSize="13sp"
            android:textStyle="bold"
            android:padding="4dp"/>

    </LinearLayout>

    <!-- Metrics row -->
    <LinearLayout
        android:id="@+id/layoutMetricas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#160837"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvMetricaSesiones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#9b59b6"
            android:textSize="12sp"
            android:gravity="center"/>

        <View
            android:layout_width="1dp"
            android:layout_height="14dp"
            android:background="#2d1654"/>

        <TextView
            android:id="@+id/tvMetricaRating"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#9b59b6"
            android:textSize="12sp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnEditarPerfilTarotista"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="✏️ Mi Perfil"
            android:textColor="#ffffff"
            android:backgroundTint="#2d1654"
            android:textSize="13sp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnDisponibilidad"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🗓 Horarios"
            android:textColor="#ffffff"
            android:backgroundTint="#4a1a8e"
            android:textSize="13sp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnAjustesTarotista"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="⚙️ Ajustes"
            android:textColor="#ffffff"
            android:backgroundTint="#2d1654"
            android:textSize="13sp"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

    <!-- Agenda section header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📅 Mi Agenda"
        android:textColor="#e8c3ff"
        android:textSize="15sp"
        android:textStyle="bold"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#1f0d40"/>

    <!-- Content area: list, empty state, and loader overlap -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAgenda"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"/>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/tvEmptyAgenda"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📭"
                android:textSize="64sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aún no tienes sesiones"
                android:textColor="#d4aaff"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configura tus horarios disponibles para que los clientes puedan agendarte."
                android:textColor="#9b59b6"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗓 Ir a Horarios →"
                android:textColor="#d4aaff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:id="@+id/tvEmptyIrHorarios"/>

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressAgenda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="#7d3cae"
            android:visibility="gone"/>

    </FrameLayout>

</LinearLayout>
