<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a0a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#2d1654"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btnCerrarPago"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#d4aaff"
            android:contentDescription="Cerrar pago"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💳 Pago Seguro"
            android:textColor="#d4aaff"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <View android:layout_width="40dp" android:layout_height="40dp"/>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressPago"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="true"
        android:indeterminateTint="#7d3cae"
        android:visibility="visible"/>

    <WebView
        android:id="@+id/webViewPago"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>
